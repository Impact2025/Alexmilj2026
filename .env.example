# Voorbeeld environment variables — kopieer naar .env.local (lokaal) en
# zet ze in Vercel Project Settings > Environment Variables (productie).
# NOOIT de waarden committen naar git.

# Neon Postgres connection string (server-only, nooit naar de client sturen)
DATABASE_URL=postgres://user:password@host.neon.tech/neondb?sslmode=require

# Geheim voor het ondertekenen van login-tokens. Gebruik een lange willekeurige string.
# Tip:  openssl rand -base64 48
AUTH_SECRET=

# Wachtwoorden (server-side geverifieerd, niet in de client-bundle)
ADMIN_PASSWORD=stel-dit-in-op-iets-sters
USER_PASSWORD=stel-dit-in-op-iets-sters
